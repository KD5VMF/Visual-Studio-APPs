<Window x:Class="AtomPlayground.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:rendering="clr-namespace:AtomPlayground.Rendering"
        mc:Ignorable="d"
        Title="Atom Playground"
        Width="1600"
        Height="960"
        MinWidth="1280"
        MinHeight="760"
        Background="#11161F"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_OnLoaded"
        KeyDown="Window_OnKeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#1A2130" />
        <SolidColorBrush x:Key="PanelBrush2" Color="#131A27" />
        <SolidColorBrush x:Key="AccentBrush" Color="#59B4FF" />
        <SolidColorBrush x:Key="AccentBrush2" Color="#7CE3C6" />
        <SolidColorBrush x:Key="TextBrush" Color="#EEF5FF" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8EA5BF" />

        <Style TargetType="Border" x:Key="CardStyle">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="6" />
            <Setter Property="BorderBrush" Value="#22314A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#243248" />
            <Setter Property="BorderBrush" Value="#31476B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="2" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2F4467" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#182436" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#1A2130" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2F4467" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#35557F" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#6F8197" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Background" Value="#243248" />
            <Setter Property="BorderBrush" Value="#31476B" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ComboToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Foreground="{TemplateBinding Foreground}"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border x:Name="MainBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        TextElement.Foreground="{TemplateBinding Foreground}"
                                        CornerRadius="10"
                                        Padding="{TemplateBinding Padding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="22" />
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Grid.Column="0"
                                                          Margin="0,0,8,0"
                                                          VerticalAlignment="Center"
                                                          TextElement.Foreground="{TemplateBinding Foreground}"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />
                                        <Path Grid.Column="1"
                                              Data="M 0 0 L 4 4 L 8 0"
                                              Stroke="{StaticResource TextBrush}"
                                              StrokeThickness="2"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   IsOpen="{TemplateBinding IsDropDownOpen}">
                                <Border Background="#162031"
                                        BorderBrush="#31476B"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="320"
                                                  CanContentScroll="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="#59B4FF" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background" Value="#2A3B57" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="Margin" Value="4" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Margin" Value="4,4,4,10" />
        </Style>

        <Style TargetType="TextBlock" x:Key="SectionHeaderStyle">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style TargetType="TextBlock" x:Key="MutedTextStyle">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top"
                Background="#121826"
                BorderBrush="#1F2C43"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Atom Playground"
                               Foreground="White"
                               FontSize="28"
                               FontWeight="Bold" />
                    <TextBlock Text="Interactive atom sandbox with switchable chemistry, nuclear, and hybrid observation modes. Full electron and nucleon views are shown with grounded, simplified physics."
                               Foreground="#8EA5BF"
                               Margin="0,2,0,0" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="Mode"
                               Foreground="#8EA5BF"
                               VerticalAlignment="Center"
                               Margin="4,0,0,0" />
                    <ComboBox x:Name="ModeComboBox"
                              Width="160"
                              SelectionChanged="ModeComboBox_OnSelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="Element"
                               Foreground="#8EA5BF"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0" />
                    <ComboBox x:Name="ElementComboBox"
                              Width="180">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="{StaticResource TextBrush}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="Spawn Atom"
                            Click="SpawnAtomButton_OnClick" />
                    <Button Content="Spawn Cluster"
                            Click="SpawnClusterButton_OnClick" />
                    <Button Content="Clear All"
                            Click="ClearAllButton_OnClick" />
                    <Button Content="Reset"
                            Click="ResetButton_OnClick" />
                    <Button x:Name="FullscreenButton"
                            Content="Fullscreen"
                            Click="ToggleFullscreenButton_OnClick" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    CornerRadius="22"
                    BorderBrush="#24314A"
                    BorderThickness="1"
                    Background="#0C1220"
                    Margin="0,0,10,0"
                    SnapsToDevicePixels="True">
                <Grid>
                    <rendering:AtomSandboxControl x:Name="SandboxControl"
                                                  SelectionChanged="SandboxControl_OnSelectionChanged"
                                                  EventLogged="SandboxControl_OnEventLogged" />

                    <Border x:Name="HelpOverlay"
                            Background="#D8101724"
                            CornerRadius="18"
                            Margin="20"
                            Padding="18"
                            Visibility="Collapsed"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top"
                            MaxWidth="430">
                        <StackPanel>
                            <TextBlock Text="How this sandbox works"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,0,0,10" />
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#E5F0FF"
                                       Margin="0,0,0,10">
                                This app uses simplified but grounded rules. Chemistry mode focuses on charge, shells, bonds, ionization, and electron transfer. Nuclear mode focuses on isotope stability, decay, fusion, and fission. Hybrid mode lets both systems interact.
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#C5D7F0"
                                       Margin="0,0,0,10">
                                Mouse controls: wheel to zoom, left-click to select, Shift+click for multi-select, and click-hold-pull-release on an atom to sling it. The farther you pull it back, the faster it flies. The visible screen is the atom world, so atoms stay inside it.
                            </TextBlock>
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="#C5D7F0"
                                       Margin="0,0,0,12">
                                Use the controls on the right to add or remove electrons, neutrons, or protons, create collisions, and toggle what is shown on screen.
                            </TextBlock>
                            <Button Content="Close"
                                    Width="120"
                                    HorizontalAlignment="Left"
                                    Click="HelpCloseButton_OnClick" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Scene controls" Style="{StaticResource SectionHeaderStyle}" />
                            <Button Content="What am I seeing?"
                                    Background="#2B4A73"
                                    Click="ShowHelpButton_OnClick" />
                            <TextBlock Text="Time scale"
                                       Style="{StaticResource MutedTextStyle}" />
                            <Slider x:Name="TimeScaleSlider"
                                    Minimum="0.1"
                                    Maximum="20"
                                    Value="1"
                                    ValueChanged="TimeScaleSlider_OnValueChanged" />
                            <TextBlock x:Name="TimeScaleText"
                                       Foreground="White"
                                       Margin="4,0,4,8"
                                       Text="1.0x" />

                            <TextBlock Text="Collision energy"
                                       Style="{StaticResource MutedTextStyle}" />
                            <Slider x:Name="CollisionEnergySlider"
                                    Minimum="5"
                                    Maximum="120"
                                    Value="40"
                                    ValueChanged="CollisionEnergySlider_OnValueChanged" />
                            <TextBlock x:Name="CollisionEnergyText"
                                       Foreground="White"
                                       Margin="4,0,4,8"
                                       Text="40" />

                            <TextBlock Text="Use the mouse wheel to zoom. Click, hold, pull back, and release an atom to sling it. This build shows electrons and nucleons directly and adds more grounded reaction channels."
                                       Style="{StaticResource MutedTextStyle}" />
                            <WrapPanel>
                                <Button Content="Smash Selected"
                                        Click="SmashSelectedButton_OnClick" />
                                <Button Content="Cool Velocities"
                                        Click="CoolVelocitiesButton_OnClick" />
                                <Button Content="Pause / Resume"
                                        Click="PauseButton_OnClick" />
                                <Button Content="Center / Fit World"
                                        Click="CenterFitButton_OnClick" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Selected atom actions" Style="{StaticResource SectionHeaderStyle}" />
                            <WrapPanel>
                                <Button Content="+ Electron"
                                        Click="AddElectronButton_OnClick" />
                                <Button Content="- Electron"
                                        Click="RemoveElectronButton_OnClick" />
                                <Button Content="+ Neutron"
                                        Click="AddNeutronButton_OnClick" />
                                <Button Content="- Neutron"
                                        Click="RemoveNeutronButton_OnClick" />
                                <Button Content="+ Proton"
                                        Click="AddProtonButton_OnClick" />
                                <Button Content="- Proton"
                                        Click="RemoveProtonButton_OnClick" />
                            </WrapPanel>
                            <TextBlock Style="{StaticResource MutedTextStyle}"
                                       Text="Adding or removing protons changes the element. In chemistry mode, electron changes are most visible. In nuclear mode, neutron and proton changes affect isotope stability." />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Display" Style="{StaticResource SectionHeaderStyle}" />
                            <WrapPanel>
                                <CheckBox x:Name="ShowHudCheckBox"
                                          Content="HUD"
                                          IsChecked="True"
                                          Checked="DisplayCheckBox_OnChanged"
                                          Unchecked="DisplayCheckBox_OnChanged" />
                                <CheckBox x:Name="ShowShellsCheckBox"
                                          Content="Electron shells"
                                          IsChecked="True"
                                          Checked="DisplayCheckBox_OnChanged"
                                          Unchecked="DisplayCheckBox_OnChanged" />
                                <CheckBox x:Name="ShowBondsCheckBox"
                                          Content="Bonds"
                                          IsChecked="True"
                                          Checked="DisplayCheckBox_OnChanged"
                                          Unchecked="DisplayCheckBox_OnChanged" />
                                <CheckBox x:Name="ShowGridCheckBox"
                                          Content="Grid"
                                          IsChecked="True"
                                          Checked="DisplayCheckBox_OnChanged"
                                          Unchecked="DisplayCheckBox_OnChanged" />
                                <CheckBox x:Name="ShowTrailsCheckBox"
                                          Content="Trails"
                                          IsChecked="False"
                                          Checked="DisplayCheckBox_OnChanged"
                                          Unchecked="DisplayCheckBox_OnChanged" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Selected atom info" Style="{StaticResource SectionHeaderStyle}" />
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Text="Name" Foreground="#8EA5BF" />
                                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="InfoNameText" Foreground="White" Text="None" />
                                <TextBlock Grid.Row="1" Text="Atomic number" Foreground="#8EA5BF" />
                                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="InfoAtomicNumberText" Foreground="White" Text="-" />
                                <TextBlock Grid.Row="2" Text="Mass number" Foreground="#8EA5BF" />
                                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="InfoMassNumberText" Foreground="White" Text="-" />
                                <TextBlock Grid.Row="3" Text="Electrons" Foreground="#8EA5BF" />
                                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="InfoElectronsText" Foreground="White" Text="-" />
                                <TextBlock Grid.Row="4" Text="Charge" Foreground="#8EA5BF" />
                                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="InfoChargeText" Foreground="White" Text="-" />
                                <TextBlock Grid.Row="5" Text="Chemistry" Foreground="#8EA5BF" />
                                <TextBlock Grid.Row="5" Grid.Column="1" x:Name="InfoChemistryText" Foreground="White" Text="-" />
                                <TextBlock Grid.Row="6" Text="Nuclear stability" Foreground="#8EA5BF" />
                                <TextBlock Grid.Row="6" Grid.Column="1" x:Name="InfoStabilityText" Foreground="White" Text="-" />
                                <TextBlock Grid.Row="7" Text="Velocity" Foreground="#8EA5BF" />
                                <TextBlock Grid.Row="7" Grid.Column="1" x:Name="InfoVelocityText" Foreground="White" Text="-" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Recent events" Style="{StaticResource SectionHeaderStyle}" />
                            <ListBox x:Name="EventListBox"
                                     Height="220"
                                     Background="#111926"
                                     BorderBrush="#23344F"
                                     Foreground="#DDEBFF" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
